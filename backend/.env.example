# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/evolved_ai

# Auth
JWT_SECRET=your-jwt-secret-here

# Google OAuth (optional — enables "Continue with Google")
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# AI (Kimi K2.5 via NVIDIA NIMs)
NVIDIA_API_KEY=nvapi-xxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# WhatsApp (via OpenClaw gateway)
WHATSAPP_GATEWAY_URL=http://localhost:3002

# Kajabi (subscription management)
KAJABI_WEBHOOK_SECRET=your-webhook-secret

# Email (Resend)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=Evolved AI <noreply@evolved.ai>

# Admin (comma-separated emails)
ADMIN_EMAILS=admin@evolved.ai

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000
