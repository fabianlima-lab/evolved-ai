# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/evolved_ai

# Auth
JWT_SECRET=your-jwt-secret-here

# Google OAuth (enables "Continue with Google")
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# AI (3-tier model routing via NVIDIA NIMs)
NVIDIA_API_KEY=nvapi-xxx

# WhatsApp (Baileys — local WhatsApp Web connection)
# Auth state is persisted to this directory (admin scans QR once)
WHATSAPP_AUTH_DIR=./baileys_auth

# Kajabi (subscription management)
KAJABI_WEBHOOK_SECRET=your-webhook-secret

# Email (Gmail SMTP — use a Gmail App Password, not your real password)
SMTP_USER=hello@yourdomain.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=Evolved AI <hello@yourdomain.com>

# Admin (comma-separated emails)
ADMIN_EMAILS=admin@evolved.ai

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000
