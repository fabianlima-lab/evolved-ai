generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Subscriber {
  id                    String    @id @default(uuid()) @db.Uuid
  email                 String    @unique @db.VarChar(255)
  passwordHash          String?   @map("password_hash") @db.VarChar(255)
  name                  String?   @db.VarChar(255)
  googleId              String?   @unique @map("google_id") @db.VarChar(255)
  googleRefreshToken    String?   @map("google_refresh_token")
  authProvider          String    @default("email") @map("auth_provider") @db.VarChar(20)
  tier                  String    @default("trial") @db.VarChar(20)
  trialEndsAt           DateTime? @map("trial_ends_at")
  goals                 String?
  whatsappJid           String?   @unique @map("whatsapp_jid") @db.VarChar(255)
  kajabiContactId       String?   @unique @map("kajabi_contact_id") @db.VarChar(255)
  kajabiOfferId         String?   @map("kajabi_offer_id") @db.VarChar(255)
  onboardingComplete    Boolean   @default(false) @map("onboarding_complete")
  assistantName         String?   @map("assistant_name") @db.VarChar(100)
  passwordResetToken    String?   @unique @map("password_reset_token") @db.VarChar(255)
  passwordResetExpiry   DateTime? @map("password_reset_expiry")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")

  agents                Agent[]
  messages              Message[]

  @@map("subscribers")
}

model Agent {
  id              String    @id @default(uuid()) @db.Uuid
  subscriberId    String    @map("subscriber_id") @db.Uuid
  name            String    @db.VarChar(100)
  systemPrompt    String    @map("system_prompt")
  soulMd          String?   @map("soul_md")
  openclawAgentId String?   @map("openclaw_agent_id") @db.VarChar(255)
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")

  subscriber      Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([subscriberId])
  @@map("agents")
}

model Message {
  id              String    @id @default(uuid()) @db.Uuid
  subscriberId    String    @map("subscriber_id") @db.Uuid
  agentId         String    @map("agent_id") @db.VarChar(50)
  role            String    @db.VarChar(20)
  channel         String    @db.VarChar(20)
  content         String
  createdAt       DateTime  @default(now()) @map("created_at")

  subscriber      Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([subscriberId, createdAt])
  @@map("messages")
}
