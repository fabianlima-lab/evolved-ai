generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Subscriber {
  id                       String    @id @default(uuid()) @db.Uuid
  email                    String    @unique @db.VarChar(255)
  passwordHash             String?   @map("password_hash") @db.VarChar(255)
  name                     String?   @db.VarChar(255)
  googleId                 String?   @unique @map("google_id") @db.VarChar(255)
  googleRefreshToken       String?   @map("google_refresh_token")
  googleAccessToken        String?   @map("google_access_token") @db.Text
  googleAccessTokenExpiry  DateTime? @map("google_access_token_expiry")
  googleScopes             String?   @map("google_scopes") @db.VarChar(500)
  authProvider             String    @default("email") @map("auth_provider") @db.VarChar(20)
  tier                     String    @default("trial") @db.VarChar(20)
  trialEndsAt              DateTime? @map("trial_ends_at")
  goals                    String?
  whatsappJid              String?   @unique @map("whatsapp_jid") @db.VarChar(255)
  kajabiContactId          String?   @unique @map("kajabi_contact_id") @db.VarChar(255)
  kajabiOfferId            String?   @map("kajabi_offer_id") @db.VarChar(255)
  kajabiPurchaseDate       DateTime? @map("kajabi_purchase_date")
  kajabiCancelDate         DateTime? @map("kajabi_cancel_date")
  onboardingComplete       Boolean   @default(false) @map("onboarding_complete")
  onboardingStep           String    @default("pending") @map("onboarding_step") @db.VarChar(30)
  profileData              Json?     @map("profile_data")
  assistantName            String?   @map("assistant_name") @db.VarChar(100)
  passwordResetToken       String?   @unique @map("password_reset_token") @db.VarChar(255)
  passwordResetExpiry      DateTime? @map("password_reset_expiry")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @default(now()) @updatedAt @map("updated_at")

  agent                    Agent?
  messages                 Message[]
  reminders                Reminder[]
  memories                 Memory[]

  @@map("subscribers")
}

model Agent {
  id              String    @id @default(uuid()) @db.Uuid
  subscriberId    String    @unique @map("subscriber_id") @db.Uuid
  name            String    @db.VarChar(100)
  systemPrompt    String    @map("system_prompt")
  soulMd          String?   @map("soul_md")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")

  subscriber      Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  messages        Message[]

  @@map("agents")
}

model Message {
  id              String    @id @default(uuid()) @db.Uuid
  subscriberId    String    @map("subscriber_id") @db.Uuid
  agentId         String    @map("agent_id") @db.Uuid
  role            String    @db.VarChar(20)
  channel         String    @db.VarChar(20)
  content         String
  createdAt       DateTime  @default(now()) @map("created_at")

  subscriber      Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  agent           Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([subscriberId, createdAt])
  @@map("messages")
}

model Reminder {
  id            String    @id @default(uuid()) @db.Uuid
  subscriberId  String    @map("subscriber_id") @db.Uuid
  agentId       String?   @map("agent_id") @db.Uuid
  title         String    @db.VarChar(500)
  dueAt         DateTime  @map("due_at")
  channel       String    @default("whatsapp") @db.VarChar(20)
  status        String    @default("pending") @db.VarChar(20)
  createdAt     DateTime  @default(now()) @map("created_at")

  subscriber    Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([subscriberId, status, dueAt])
  @@index([status, dueAt])
  @@map("reminders")
}

model Memory {
  id            String    @id @default(uuid()) @db.Uuid
  subscriberId  String    @map("subscriber_id") @db.Uuid
  category      String    @db.VarChar(30)
  fact          String    @db.VarChar(300)
  source        String    @default("ai") @db.VarChar(20)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  subscriber    Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([subscriberId, category])
  @@map("memories")
}
